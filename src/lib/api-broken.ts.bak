// Soal Management Types
export type PilihanJawaban = {
  id: number;
  soal_id: number;
  option_text: string;
  is_correct: boolean;
};

export type Soal = {
  id: number;
  question: string;
  explanation: string;
  pilihan_jawaban: PilihanJawaban[];
};

export type SoalsByPaketResponse = {
  success: boolean;
  message: string;
  data?: Soal[];
  error?: string;
};

export type SoalsResponse = {
  success: boolean;
  message: string;
  data?: {
    data: Soal[];
    page: number;
    limit: number;
    total_items: number;
    total_pages: number;
  };
  error?: string;
};

export type AssignSoalRequest = {
  paket_id: number;
  soal_id: number;
};

export type AssignSoalResponse = {
  success: boolean;
  message: string;
};

export type RemoveSoalRequest = {
  paket_id: number;
  soal_id: number;
};

export type RemoveSoalResponse = {
  success: boolean;
  message: string;
};

// Soal Management Functions
export async function getSoalsByPaket(
  paketId: number,
  signal?: AbortSignal
): Promise<SoalsByPaketResponse> {
  const token = getToken();
  if (!token) {
    throw new Error("No authentication token");
  }

  const res = await fetch(`${API_BASE_URL}/pakets/${paketId}/soals`, {
    method: "GET",
    headers: {
      ...baseHeaders,
      Authorization: `Bearer ${token}`,
    },
    signal,
  });

  const contentType = res.headers.get("content-type") || "";
  const isJson = contentType.includes("application/json");
  const data = isJson
    ? await res.json()
    : { success: false, message: await res.text() };
  return data as SoalsByPaketResponse;
}

export async function getAllSoals(signal?: AbortSignal): Promise<SoalsResponse> {
  const token = getToken();
  const response = await fetch(`${API_BASE_URL}/soals`, {
    signal,
    headers: {
      ...baseHeaders,
      Authorization: `Bearer ${token}`,
    },
  });
  if (!response.ok) {
    throw new Error("Gagal mengambil data soal");
  }
  return response.json();
}

export async function createSoal(soalData: {
  question: string;
  option_a: string;
  option_b: string;
  option_c: string;
  option_d: string;
  correct_answer: string;
}): Promise<ApiResponse> {
  const token = getToken();
  const response = await fetch(`${API_BASE_URL}/soals`, {
    method: "POST",
    headers: {
      ...baseHeaders,
      Authorization: `Bearer ${token}`,
    },
    body: JSON.stringify(soalData),
  });
  const data = await response.json();
  if (!response.ok) {
    throw new Error(data.message || "Gagal membuat soal");
  }
  return data;
}

